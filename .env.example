# Phase 0 environment template — copy to .env and fill in production values.

# ---------- Postgres ----------
POSTGRES_PASSWORD=replace-this-in-prod
POSTGRES_DSN=postgresql+psycopg://agent:replace-this-in-prod@postgres:5432/workspace_agent

# ---------- Redis ----------
REDIS_URL=redis://redis:6379/0

# ---------- OIDC (Authentik) ----------
OIDC_ISSUER=http://authentik:9000/application/o/workspace-agent/
OIDC_AUDIENCE=workspace-agent
OIDC_CLIENT_ID=workspace-agent
OIDC_CLIENT_SECRET=replace-with-authentik-secret
OIDC_JWKS_URL=http://authentik:9000/application/o/workspace-agent/jwks/

# Set to 1 to bypass token verification (DEV ONLY — opens the API to anyone)
ENABLE_MCP_HTTP_NOAUTH=0

AUTHENTIK_SECRET_KEY=generate-a-long-random-string-for-prod

# ---------- MCP HTTP transport ----------
# Set to 1 to mount /mcp endpoint on the FastAPI app
ENABLE_MCP_HTTP=1

# ---------- OpenTelemetry ----------
# OTLP collector endpoint (use the otel_collector service from docker-compose)
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel_collector:4317
OTEL_SERVICE_NAME=workspace-agent

# ---------- Sheets read cache (Phase 14E opt-in) ----------
SHEETS_READ_CACHE=0

# ---------- Live tests ----------
# Set to 1 to enable integration tests against real Google APIs
LIVE_GOOGLE_TESTS=0
# Per-vendor live test toggles (each runs independently)
LIVE_WB_TESTS=0
LIVE_OZON_TESTS=0
LIVE_YAMARKET_TESTS=0
LIVE_MOYSKLAD_TESTS=0
LIVE_TG_TESTS=0
